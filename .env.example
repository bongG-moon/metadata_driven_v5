# Copy this file to .env and fill in real values.
# Do not commit real secrets.

# Runtime
AGENT_ENV=local
AGENT_TIMEZONE=Asia/Seoul
AGENT_DEFAULT_DATE=20260612

# Langflow Desktop / Web API
# Example full run URL:
#   http://127.0.0.1:7860/api/v1/run/<flow_id>
LANGFLOW_BASE_URL=http://127.0.0.1:7860
LANGFLOW_API_KEY=
LANGFLOW_INPUT_TYPE=chat
LANGFLOW_OUTPUT_TYPE=chat
LANGFLOW_TIMEOUT_SECONDS=300
DATA_REF_DOWNLOAD_HOST=127.0.0.1
DATA_REF_DOWNLOAD_PORT=8765

# Langflow Desktop backend storage controls are configured in
# %APPDATA%\com.LangflowDesktop\data\.env, not only in this web-app .env.
# Restart Langflow Desktop after changing them.
# LANGFLOW_NATIVE_TRACING=false
# LANGFLOW_VERTEX_BUILDS_STORAGE_ENABLED=false

# Optional router flow. If this is empty, the Streamlit chat calls the data analysis flow directly.
LANGFLOW_ROUTER_FLOW_ID=
LANGFLOW_ROUTER_API_URL=

# Current v5 analysis flow.
LANGFLOW_DATA_ANALYSIS_FLOW_ID=
LANGFLOW_DATA_ANALYSIS_API_URL=

# Optional metadata QA flow routed by the router.
LANGFLOW_METADATA_QA_FLOW_ID=
LANGFLOW_METADATA_QA_API_URL=

# Metadata saving flows used by the web metadata management screens.
LANGFLOW_DOMAIN_SAVING_FLOW_ID=
LANGFLOW_DOMAIN_SAVING_API_URL=
LANGFLOW_TABLE_CATALOG_SAVING_FLOW_ID=
LANGFLOW_TABLE_CATALOG_SAVING_API_URL=
LANGFLOW_MAIN_FILTER_SAVING_FLOW_ID=
LANGFLOW_MAIN_FILTER_SAVING_API_URL=
LANGFLOW_MAIN_FLOW_FILTER_SAVING_API_URL=

# LLM validation
# This project follows the previous rebuild folder:
# - use Google Gemini through langchain_google_genai.ChatGoogleGenerativeAI
# - keep provider-neutral names so Langflow and Python validation can share them
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60

# Optional aliases for tools that expect Google's conventional variable names.
# Keep them empty unless your local tooling needs them.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# MongoDB metadata/result store
MONGODB_URI=
MONGODB_DATABASE=datagov
MONGODB_DOMAIN_COLLECTION=agent_v4_domain_items
MONGODB_TABLE_CATALOG_COLLECTION=agent_v4_table_catalog_items
MONGODB_MAIN_FLOW_FILTER_COLLECTION=agent_v4_main_flow_filters
MONGODB_RESULT_COLLECTION=agent_v4_result_store
MONGODB_SESSION_STATE_COLLECTION=agent_v4_session_states

# Source retrieval
# Select dummy/live once in Langflow node `04A 신뢰 카탈로그 조회 작업 구성기.retrieval_mode`.
# The source credentials below are used only when that single mode is `live`.
# JSON example: {"PNT_RPT":{"user":"USER","password":"PASSWORD","dsn":"(DESCRIPTION=...)"}}
# Langflow Oracle 설정/TNS input can also receive a named TNS block such as `PNT_RPT: (DESCRIPTION=...)`.
ORACLE_CONFIG_JSON=
H_API_TOKEN=
LAKEHOUSE_USER_ID=
LAKEHOUSE_TOKEN=
LAKEHOUSE_S3_ACCESS_KEY=
LAKEHOUSE_S3_SECRET_KEY=
GOODOCS_USER_ID=
GOODOCS_TOKEN_SOURCE=
GOODOCS_TOKEN_KEY=
GOODOCS_MODULE_NAME=
SOURCE_FETCH_LIMIT=5000

# Validation switches
RUN_LLM_VALIDATION=false
RUN_MONGODB_VALIDATION=false
RUN_LANGFLOW_API_VALIDATION=false
VALIDATION_LIMIT=
